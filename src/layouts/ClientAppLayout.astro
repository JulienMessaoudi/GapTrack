---
type Props = {
  title: string;
  description: string;
  canonicalPath: string;
};

const { title, description, canonicalPath } = Astro.props;

const siteUrl = "https://gaptrack-ssi.vercel.app";
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#071126" />

    <style is:global>
      html,
      body {
        margin: 0;
        min-height: 100%;
        background: #071126;
        color: #f8fbff;
        overflow-x: hidden;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      .gt-client-loading {
        min-height: 100dvh;
        display: grid;
        place-items: center;
        padding: 24px;
        color: #f8fbff;
        background:
          radial-gradient(circle at 78% 14%, rgba(43, 114, 255, 0.30), transparent 29%),
          radial-gradient(circle at 17% 88%, rgba(35, 110, 255, 0.22), transparent 31%),
          linear-gradient(135deg, #081126 0%, #050a18 48%, #07152d 100%);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      .gt-client-loading-card {
        min-width: min(360px, calc(100vw - 48px));
        padding: 28px;
        border: 1px solid rgba(158, 178, 215, .24);
        border-radius: 18px;
        display: grid;
        justify-items: center;
        gap: 10px;
        background: rgba(8, 18, 38, .74);
        box-shadow: 0 30px 90px rgba(0, 0, 0, .32);
        text-align: center;
      }

      .gt-client-loading-card img {
        width: 54px;
        height: 54px;
        display: block;
      }

      .gt-client-loading-card strong {
        font-size: 24px;
        line-height: 1;
      }

      .gt-client-loading-card span,
      .gt-noscript {
        color: #b9c4d6;
        font-size: 14px;
      }

      .gt-noscript {
        display: block;
        padding: 20px;
        text-align: center;
      }
    </style>
  </head>

  <body>
    <slot />
    <noscript>
      <span class="gt-noscript">
        JavaScript est nécessaire pour accéder à l’espace privé GapTrack.
      </span>
    </noscript>
  </body>
</html>
